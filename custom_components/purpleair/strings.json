{
  "config": {
    "abort": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]",
      "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]"
    },
    "error": {
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
      "invalid_api_key": "[%key:common::config_flow::error::invalid_api_key%]",
      "key_disabled": "This API key has been disabled. Please contact PurpleAir support.",
      "unknown": "[%key:common::config_flow::error::unknown%]",
      "wrong_key_type": "Use your PurpleAir READ key, not the WRITE key."
    },
    "step": {
      "api_key": {
        "data": {
          "api_key": "[%key:common::config_flow::data::api_key%]"
        },
        "description": "Enter PurpleAir API read key",
        "title": "[%key:common::config_flow::data::api_key%]"
      },
      "reauth_confirm": {
        "data": {
          "api_key": "[%key:common::config_flow::data::api_key%]"
        },
        "description": "Change PurpleAir API read key",
        "title": "Re-authenticate"
      },
      "reconfigure": {
        "data": {
          "api_key": "[%key:common::config_flow::data::api_key%]"
        },
        "description": "Change PurpleAir API read key",
        "title": "Reconfigure"
      }
    }
  },
  "config_subentries": {
    "sensor": {
      "abort": {
        "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
      },
      "error": {
        "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
        "invalid_api_key": "[%key:common::config_flow::error::invalid_api_key%]",
        "invalid_read_key": "That sensor read key does not match the sensor. Check the key from the PurpleAir registration and try again.",
        "no_sensor_found": "Sensors not found",
        "no_sensors_found": "No sensors found in search area",
        "unknown": "[%key:common::config_flow::error::unknown%]"
      },
      "initiate_flow": {
        "user": "Add PurpleAir sensor"
      },
      "step": {
        "add_map_location": {
          "data": {
            "latitude": "[%key:common::config_flow::data::latitude%]",
            "longitude": "[%key:common::config_flow::data::longitude%]",
            "radius": "Radius (m)"
          },
          "description": "Search for sensors in the circle on the map",
          "title": "Add sensor from map"
        },
        "add_options": {
          "menu_options": {
            "add_map_location": "Add sensor from map location",
            "add_sensor_index": "Add sensor by index and optional read key"
          },
          "title": "Add sensor"
        },
        "add_sensor_index": {
          "data": {
            "sensor_index": "Sensor index",
            "sensor_read_key": "Sensor read key"
          },
          "description": "Enter sensor identification details",
          "title": "Sensor details"
        },
        "select_sensor": {
          "data": {
            "sensor_index": "Sensor"
          },
          "description": "Select sensor to add",
          "title": "Select sensor"
        }
      }
    }

#!/usr/bin/env bash
# Install dev requirements for this repo:
#   1. Python base + test requirements (requirements.txt, requirements-test.txt).
#   2. Editable checkout of aiopurpleair at ./aiopurpleair (gitignored),
#      replacing the pinned PyPI install with your local fork for in-container dev.
#   3. go2rtc binary pinned to GO2RTC_VERSION with per-arch SHA256 verification.
#   4. HACS pinned to HACS_VERSION, downloaded as a GitHub release artifact and
#      SHA256-verified before being extracted into config/custom_components/hacs/.
#   5. markdownlint-cli2 pinned via npm — same engine the VS Code
#      davidanson.vscode-markdownlint extension uses, so CLI verification matches
#      what the IDE shows. Node.js itself is provided by the devcontainer
#      `node:2` feature.
#
# Neither the go2rtc upstream nor HACS publish checksum files alongside their
# release assets, so the hashes below are computed manually when bumping and
# hard-coded here. Regenerate with:
#   curl -fsSL <asset-url> | sha256sum

set -euo pipefail

cd "$(dirname "$0")/.."

python3 -m pip install --requirement requirements.txt
python3 -m pip install --requirement requirements-test.txt

# --- markdownlint-cli2 ----------------------------------------------------
# Pinned npm-installed binary so `markdownlint-cli2 README.md AGENTS.md ...`
# CLI runs match the davidanson.vscode-markdownlint extension's output.
# Node.js is supplied by the `ghcr.io/devcontainers/features/node:2`
# devcontainer feature; if it's missing (e.g. running scripts/setup outside
# the devcontainer) we just skip — markdown linting is IDE-driven and not
# part of the CI gate.
MARKDOWNLINT_VERSION=0.22.1

if command -v npm >/dev/null 2>&1; then
    installed_markdownlint=""
    if command -v markdownlint-cli2 >/dev/null 2>&1; then
        installed_markdownlint="$(markdownlint-cli2 --version 2>/dev/null \
            | awk '{print $2}' | tr -d 'v')"
    fi
    if [[ "${installed_markdownlint}" = "${MARKDOWNLINT_VERSION}" ]]; then
        echo "markdownlint-cli2 ${MARKDOWNLINT_VERSION} already installed, skipping."
    else
        echo "Installing markdownlint-cli2@${MARKDOWNLINT_VERSION} via npm"
        npm install -g "markdownlint-cli2@${MARKDOWNLINT_VERSION}"
        # Avoid piping to `head` here; Node 24 can raise EPIPE on closed stdout.
        installed_markdownlint="$(markdownlint-cli2 --version 2>/dev/null)"
        installed_markdownlint="${installed_markdownlint%%$'\n'*}"
        echo "Installed: ${installed_markdownlint}"
    fi
else
    echo "npm not available; skipping markdownlint-cli2 install (IDE-only tool)." >&2
fi

# --- aiopurpleair checkout ------------------------------------------------
# Local editable install of the aiopurpleair fork inside the repo root (gitignored).
# Edits to the library flow through to both `scripts/develop` (HA runtime) and
# pytest without round-tripping through PyPI.
#
# Lives inside the repo (not /workspaces/) because /workspaces is root-owned in
# devcontainers and `vscode` can't create siblings there.
#
# The version check below trips loudly if your fork's pyproject.toml version
# diverges from the manifest.json pin -- otherwise HA's package check would silently
# reinstall aiopurpleair==<pinned> from PyPI at integration load, overwriting the
# editable install.
AIOPURPLEAIR_DIR="$(pwd)/aiopurpleair"
AIOPURPLEAIR_REPO=https://github.com/ptr727/bachya-aiopurpleair.git
AIOPURPLEAIR_BRANCH=dev
USE_EDITABLE_AIOPURPLEAIR=true

if [[ ! -d "${AIOPURPLEAIR_DIR}" ]]; then
    echo "Cloning ${AIOPURPLEAIR_REPO} (${AIOPURPLEAIR_BRANCH}) into ${AIOPURPLEAIR_DIR}"
    if ! git clone --branch "${AIOPURPLEAIR_BRANCH}" "${AIOPURPLEAIR_REPO}" "${AIOPURPLEAIR_DIR}"; then
        echo "Warning: Failed to clone ${AIOPURPLEAIR_REPO}. Continuing without editable aiopurpleair checkout." >&2
        USE_EDITABLE_AIOPURPLEAIR=false
    fi
else
    echo "${AIOPURPLEAIR_DIR} already exists, skipping clone."
fi

if [[ "${USE_EDITABLE_AIOPURPLEAIR}" = true ]] && [[ -d "${AIOPURPLEAIR_DIR}" ]]; then
    # Do not auto-run aiopurpleair's Poetry bootstrap in this environment.
    # Its lock file may target a different Python minor (for example older
    # frozenlist/multidict builds that fail on 3.14), and this repo's setup
    # should stay deterministic for Home Assistant development.
    #
    # For this workspace we only need aresponses available for aiopurpleair
    # tests; install it directly if missing.
    if ! python3 -c 'import aresponses' >/dev/null 2>&1; then
        python3 -m pip install "aresponses>=2.1.6,<4.0.0"
    fi

    # Optional escape hatch for contributors who explicitly want to run the
    # library's own setup flow in its own repo context.
    if [[ "${RUN_AIOPURPLEAIR_SETUP:-0}" = "1" ]] || [[ "${RUN_AIOPURPLEAIR_SETUP:-}" =~ ^([Tt]rue|TRUE|yes|YES)$ ]]; then
        if [[ -x "${AIOPURPLEAIR_DIR}/script/setup" ]]; then
            echo "RUN_AIOPURPLEAIR_SETUP enabled; running ${AIOPURPLEAIR_DIR}/script/setup"
            if ! (cd "${AIOPURPLEAIR_DIR}" && ./script/setup); then
                echo "Warning: aiopurpleair setup failed; continuing with editable install." >&2
            fi
        else
            echo "Warning: aiopurpleair setup script not found; skipping optional aiopurpleair setup." >&2
        fi
    fi

    python3 -m pip install --editable "${AIOPURPLEAIR_DIR}"

    python3 <<'PYEOF'
import json, pathlib
from importlib.metadata import version
from packaging.version import Version
manifest = json.loads(pathlib.Path("custom_components/purpleair/manifest.json").read_text())
req = next(r for r in manifest["requirements"] if r.startswith("aiopurpleair"))
# Accept either a `==X.Y.Z` PyPI pin or a `@ git+…@SHA` git ref. With a git ref
# the version assertion is skipped — the SHA is the source of truth and pip's
# importlib.metadata still reports the version baked into the editable
# checkout's pyproject.toml, which can lag the SHA freely.
if "==" in req:
    pkg_name, expected = req.split("==", 1)
    pkg_name = pkg_name.strip()
    installed = version(pkg_name)
    if Version(installed) != Version(expected):
        raise RuntimeError(
            f"{pkg_name} editable install reports {installed}; manifest.json expects {expected}. "
            f"Sync the fork's pyproject.toml version, or update manifest.json + requirements-test.txt."
        )
    print(f"{pkg_name} editable install verified at version {installed}")
else:
    pkg_name = req.split("@", 1)[0].strip()
    print(f"{pkg_name} pinned at git ref ({req}); skipping version assertion.")
PYEOF
else
    echo "Skipping editable aiopurpleair install and editable-version assertion."
fi

# --- go2rtc ---------------------------------------------------------------
# Required by HA's default_config. The HA Docker image bundles it; bare dev
# environments must install it manually. Keep GO2RTC_VERSION in sync with
# RECOMMENDED_VERSION in homeassistant/components/go2rtc/const.py.
GO2RTC_VERSION=1.9.14

installed_version="$(go2rtc --version 2>/dev/null | head -n1 || true)"
if [[ "${installed_version}" = "go2rtc version ${GO2RTC_VERSION}" ]]; then
    echo "go2rtc ${GO2RTC_VERSION} already installed, skipping."
else
    machine="$(uname -m)"
    case "${machine}" in
        x86_64)
            arch=amd64
            expected_sha=32d616af226bd731678ffde328b94cfb94e30339bfefc469cfb76323144615a6
            ;;
        aarch64)
            arch=arm64
            expected_sha=359fabade8a7a51e81a55fe6df6b0ef81764a5e1d63179577534eaaa71904b50
            ;;
        armv7l)
            arch=arm
            expected_sha=4d7e1639af5a2722a28e864468fd8099b3c1682565446c798bf9e3b38fde12e4
            ;;
        *)
            echo "Unsupported architecture: ${machine}" >&2
            exit 1
            ;;
    esac
    url="https://github.com/AlexxIT/go2rtc/releases/download/v${GO2RTC_VERSION}/go2rtc_linux_${arch}"
    tmp=$(mktemp)
    trap 'rm -f "$tmp"' EXIT
    echo "Downloading go2rtc ${GO2RTC_VERSION} (${arch}) from ${url}"
    curl -fsSL "${url}" -o "${tmp}"

    actual_sha=$(sha256sum "${tmp}" | awk '{print $1}')
    if [[ "${actual_sha}" != "${expected_sha}" ]]; then
        echo "go2rtc checksum mismatch!" >&2
        echo "  expected: ${expected_sha}" >&2
        echo "  actual:   ${actual_sha}" >&2
        exit 1
    fi
    echo "Verified sha256 ${expected_sha}"

    sudo install -m 0755 "${tmp}" /usr/local/bin/go2rtc
    # Explicit cleanup before clearing the trap so an interruption (SIGINT)
    # or failed rm during this window still falls back to the trap.
    rm -f "${tmp}"
    trap - EXIT
    installed_version="$(go2rtc --version | head -n1)"
    echo "Installed: ${installed_version}"
fi

# --- actionlint -----------------------------------------------------------
# Workflow linter — same tool used by `actionlint -color .github/workflows/*.yml`
# in CI advice. Pinned with per-arch SHA256 from upstream's checksums.txt.
ACTIONLINT_VERSION=1.7.7

installed_actionlint="$(actionlint -version 2>/dev/null | head -n1 || true)"
if [[ "${installed_actionlint}" = "${ACTIONLINT_VERSION}" ]]; then
    echo "actionlint ${ACTIONLINT_VERSION} already installed, skipping."
else
    machine="$(uname -m)"
    case "${machine}" in
        x86_64)
            arch=amd64
            actionlint_sha=023070a287cd8cccd71515fedc843f1985bf96c436b7effaecce67290e7e0757
            ;;
        aarch64)
            arch=arm64
            actionlint_sha=401942f9c24ed71e4fe71b76c7d638f66d8633575c4016efd2977ce7c28317d0
            ;;
        armv7l)
            arch=armv6
            actionlint_sha=82e98d7252341b83fa557764824f225fa50431801b8e3d8e99f70dc1efc317b2
            ;;
        *)
            echo "Unsupported architecture for actionlint: ${machine}" >&2
            exit 1
            ;;
    esac
    url="https://github.com/rhysd/actionlint/releases/download/v${ACTIONLINT_VERSION}/actionlint_${ACTIONLINT_VERSION}_linux_${arch}.tar.gz"
    tmp=$(mktemp)
    extract_dir=$(mktemp -d)
    # Trap covers both the download tarball and the extract dir so a failure
    # in tar / install / sha-verify doesn't leak temp directories.
    trap 'rm -rf "$extract_dir"; rm -f "$tmp"' EXIT
    echo "Downloading actionlint ${ACTIONLINT_VERSION} (${arch}) from ${url}"
    curl -fsSL "${url}" -o "${tmp}"

    actual_sha=$(sha256sum "${tmp}" | awk '{print $1}')
    if [[ "${actual_sha}" != "${actionlint_sha}" ]]; then
        echo "actionlint checksum mismatch!" >&2
        echo "  expected: ${actionlint_sha}" >&2
        echo "  actual:   ${actual_sha}" >&2
        exit 1
    fi
    echo "Verified sha256 ${actionlint_sha}"

    tar -xzf "${tmp}" -C "${extract_dir}" actionlint
    sudo install -m 0755 "${extract_dir}/actionlint" /usr/local/bin/actionlint
    # Explicit cleanup runs before disabling the trap so that an interruption
    # (SIGINT) or a failed rm during this window still falls back to the trap
    # as a safety net. trap is only cleared after both resources are gone.
    rm -rf "${extract_dir}"
    rm -f "${tmp}"
    trap - EXIT
    installed_actionlint="$(actionlint -version | head -n1)"
    echo "Installed: actionlint ${installed_actionlint}"
fi

# --- HACS -----------------------------------------------------------------
# https://www.hacs.xyz/
# Pinned release-artifact install (replaces the legacy `curl | bash` installer).
HACS_VERSION=2.0.5
HACS_SHA256=97be6b824a4f38e683728cc6dd72367f6b8bad0a43428b1b3b987a3087adf413

if [[ -f config/custom_components/hacs/manifest.json ]]; then
    echo "HACS already installed, skipping."
else
    url="https://github.com/hacs/integration/releases/download/${HACS_VERSION}/hacs.zip"
    tmp=$(mktemp)
    trap 'rm -f "$tmp"' EXIT
    echo "Downloading HACS ${HACS_VERSION} from ${url}"
    curl -fsSL "${url}" -o "${tmp}"

    actual_sha=$(sha256sum "${tmp}" | awk '{print $1}')
    if [[ "${actual_sha}" != "${HACS_SHA256}" ]]; then
        echo "HACS checksum mismatch!" >&2
        echo "  expected: ${HACS_SHA256}" >&2
        echo "  actual:   ${actual_sha}" >&2
        exit 1
    fi
    echo "Verified sha256 ${HACS_SHA256}"

    mkdir -p config/custom_components/hacs
    python3 -m zipfile -e "${tmp}" config/custom_components/hacs/
    # Explicit cleanup before clearing the trap so an interruption (SIGINT)
    # or failed rm during this window still falls back to the trap.
    rm -f "${tmp}"
    trap - EXIT
    echo "Installed HACS ${HACS_VERSION}"
fi

#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Create config dir if not present
if [[ ! -d "${PWD}/config" ]]; then
    mkdir -p "${PWD}/config"
    hass --config "${PWD}/config" --script ensure_config
fi

# Set the path to custom_components
## This lets us have the structure we want <root>/custom_components/purpleair
## while at the same time have Home Assistant configuration inside <root>/config
## without resulting to symlinks.
# `${PYTHONPATH:-}` keeps `set -u` happy when the variable is unset (default
# outside venvs).
export PYTHONPATH="${PYTHONPATH:-}:${PWD}/custom_components"

# Start Home Assistant.
# --skip-pip-packages aiopurpleair preserves the editable install from
# scripts/setup; otherwise HA's package check would reinstall the pinned
# aiopurpleair==<version> from PyPI on every launch, clobbering ./aiopurpleair.
hass --config "${PWD}/config" --debug --skip-pip-packages aiopurpleair
